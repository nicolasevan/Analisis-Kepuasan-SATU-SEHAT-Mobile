import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns
import re
from collections import Counter
from wordcloud import WordCloud
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import classification_report, accuracy_score, confusion_matrix
from sklearn.feature_extraction.text import CountVectorizer


# 1. LOAD DATA & CLEANING

df = pd.read_csv('satusehat.csv')

df = df.dropna(subset=['content'])

# Pelabelan: Hapus rating 3 (Netral), 1-2 Negatif, 4-5 Positif
df = df[df['score'] != 3]
df['label_name'] = df['score'].apply(lambda x: 'Positif' if x >= 4 else 'Negatif')
df['label_bin'] = df['score'].apply(lambda x: 1 if x >= 4 else 0)


# 2. PREPROCESSING TEKS

# Daftar stopword sederhana bahasa Indonesia
stopwords_id = {
    'dan', 'yang', 'di', 'ke', 'dari', 'ini', 'itu', 'ada', 'adalah', 'untuk',
    'dengan', 'saya', 'aplikasi', 'sudah', 'bisa', 'gak', 'ga', 'tdk', 'aja', 'banget',
    'tapi', 'kalau', 'kalo', 'udah', 'jadi', 'ya', 'yg', 'sdh', 'buat', 'biasa',
    
}

def clean_text(text):
    # Case folding
    text = str(text).lower()
    # Menghapus karakter selain huruf a-z
    text = re.sub(r'[^a-z\s]', '', text)
    # Tokenizing & Stopword removal
    words = [w for w in text.split() if w not in stopwords_id and len(w) > 2]
    return " ".join(words)

df['clean_text'] = df['content'].apply(clean_text)


# 3. PEMODELAN STATISTIKA (NAIVE BAYES)
  
X_train, X_test, y_train, y_test = train_test_split(
    df['clean_text'], df['label_bin'], test_size=0.2, random_state=42
)

# Ekstraksi Fitur dengan TF-IDF
tfidf = TfidfVectorizer(max_features=5000)
X_train_tfidf = tfidf.fit_transform(X_train)
X_test_tfidf = tfidf.transform(X_test)

# Model Naive Bayes
model = MultinomialNB()
model.fit(X_train_tfidf, y_train)

# Prediksi & Evaluasi
y_pred = model.predict(X_test_tfidf)
print("\n--- HASIL EVALUASI MODEL ---")
print(f"Akurasi Total: {accuracy_score(y_test, y_pred):.3f}")
print(classification_report(y_test, y_pred, target_names=['Negatif', 'Positif']))


