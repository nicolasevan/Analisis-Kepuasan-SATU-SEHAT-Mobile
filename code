plt.figure(figsize=(10, 5))
sns.barplot(x=[f[1] for f in neg_tg], y=[f[0] for f in neg_tg], palette='Oranges_r')
plt.title('Top 10 Trigrams - Sentimen Negatif')
plt.show()
