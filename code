# Fungsi pembersihan khusus N-Gram
def clean_for_ngram(text):
    text = str(text).lower()
    text = re.sub(r'[^a-z\s]', '', text)
    # Stopwords sederhana
    stopwords = {'dan', 'yang', 'di', 'ke', 'dari', 'ini', 'itu', 'ada', 'untuk', 'dengan', 'saya', 'aplikasi', 'sudah', 'bisa', 'banget'}
    words = [w for w in text.split() if w not in stopwords]
    return " ".join(words)

# Fungsi untuk mengambil N-Gram teratas
def get_top_ngrams(corpus, n=10, n_range=(2,2)):
    vec = CountVectorizer(ngram_range=n_range).fit(corpus)
    bag_of_words = vec.transform(corpus)
    sum_words = bag_of_words.sum(axis=0)
    words_freq = [(word, sum_words[0, idx]) for word, idx in vec.vocabulary_.items()]
    words_freq = sorted(words_freq, key = lambda x: x[1], reverse=True)
    return words_freq[:n]

# Persiapan data
df_clean = df.dropna(subset=['content']).copy()
df_pos = df_clean[df_clean['score'] >= 4].copy()
df_neg = df_clean[df_clean['score'] <= 2].copy()

df_pos['ngram_text'] = df_pos['content'].apply(clean_for_ngram)
df_neg['ngram_text'] = df_neg['content'].apply(clean_for_ngram)

# Trigram Positif
pos_tg = get_top_ngrams(df_pos['ngram_text'], n=10, n_range=(3,3))
plt.figure(figsize=(10, 5))
sns.barplot(x=[f[1] for f in pos_tg], y=[f[0] for f in pos_tg], palette='GnBu_r')
plt.title('Top 10 Trigrams - Sentimen Positif')
plt.show()

# Trigram Negatif
